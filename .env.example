# Salin file ini menjadi .env dan isi dengan nilai asli Anda
# Jangan pernah commit file .env ke GitHub!

# Gemini AI API Key (opsional, tanpa ini mode audit-lokal saja)
GEMINI_API_KEY=your_gemini_api_key_here

# Port server (default: 4500)
PORT=4500

# Secret Key untuk menandatangani Token JWT (Keamanan API)
JWT_SECRET=your_jwt_secret_key_here

# Database PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/sppg_db

# URL Google Apps Script untuk sinkronisasi spreadsheet (opsional)
SPREADSHEET_CENTRAL_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Integrasi Aplikasi Akuntansi Kledo (Opsional)
# Isikan detail berikut dari Akun Kledo Anda (Pengaturan > Integrasi > Open API)
KLEDO_API_URL=https://api.kledo.com/v1
KLEDO_API_TOKEN=Bearer_YOUR_KLEDO_API_BEARER_TOKEN
KLEDO_EXPENSE_ACCOUNT_ID=YOUR_CHART_OF_ACCOUNTS_ID_FOR_FOOD_EXPENSES
